# Telegram Stremio — startup configuration only
# Fill these in Hugging Face Space Secrets/Variables or config.env before first start.
# Everything else is configured from Admin → Config and applies immediately.

# Telegram (Required)
API_ID=""
API_HASH=""
BOT_TOKEN=""
HELPER_BOT_TOKEN=""
OWNER_ID=""

# Database (Required — comma-separated URIs, exactly 2: tracking, storage_1)
DATABASE=""

# Server (Required)
# Hugging Face Docker Spaces use 7860. VPS deployments can use 8000.
PORT="7860"

# Optional extra Telegram streaming bots
# Add these securely after startup in Admin → Config → Multi-Bot Tokens.
# Do not add MULTI_TOKEN1… values here unless you are migrating a legacy setup.
# Optional host safety cap for simultaneous stream bots. Keep 0 to let the
# router use every healthy connected bot automatically (recommended).
STREAM_MAX_PARALLEL_BOTS="0"

